{
  "name": "bookmarkit",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite build --mode development",
    "build": "vite build",
    "build:chrome": "vite build && node scripts/build-chrome.js",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "licenses:notices": "node scripts/generate-third-party-notices.mjs",
    "licenses:notices:check": "node scripts/generate-third-party-notices.mjs --check",
    "changeset": "changeset",
    "changeset:version": "changeset version && node scripts/sync-manifest-version.mjs",
    "check:version-policy": "node scripts/check-version-policy.mjs",
    "package:release": "npm run build:chrome && node scripts/check-version-policy.mjs --built && node scripts/package-release.mjs",
    "ci": "npm run check:version-policy && npm run licenses:notices:check && npm run format:check && npm run lint && npm run test && npm run build:chrome && npm run build:storybook",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "firebase": "^10.0.0",
    "js-yaml": "^4.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-window": "^1.8.10"
  },
  "overrides": {
    "firebase": {
      "undici": "^6.27.0"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.33.0",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-vitest-globals": "^1.6.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.47",
    "prettier": "^3.9.5",
    "storybook": "^10.5.3",
    "tailwindcss": "^3.4.14",
    "vite": "^7.3.2",
    "vitest": "^4.1.10"
  }
}
